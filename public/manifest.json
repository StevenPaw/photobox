{
  "name": "Photobox",
  "short_name": "Photobox",
  "description": "Eine interaktive Photobox für Events und Gäste",
  "start_url": "/",
  "scope": "/",
  "display": "fullscreen",
  "orientation": "portrait",
  "theme_color": "#4E9DAE",
  "background_color": "#ffffff",
  "icons": [
    {
      "src": "/pwa-64x64.svg",
      "sizes": "64x64",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/pwa-192x192.svg",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/pwa-512x512.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/maskable-icon-512x512.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "maskable"
    }
  ],
  "permissions": [
    "camera",
    "storage"
  ],
  "features": [
    "camera"
  ],
  "categories": ["photo", "entertainment"],
  "prefer_related_applications": false
}

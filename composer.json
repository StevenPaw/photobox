{
    "name": "atwx/nopages-silverstripe-template",
    "type": "project",
    "authors": [
        {
            "name": "Andy Adiwidjaja",
            "email": "adiwidjaja@gmail.com"
        },
        {
            "name": "Steffen Kahl",
            "email": "sk@adiwidjaja.com"
        }
    ],
    "repositories": [
        {
            "type": "git",
            "url": "https://github.com/wernerkrauss/silverstripe-pure-modal.git"
        },
        {
            "type": "git",
            "url": "https://github.com/atwx/silverstripe-projectinfo.git"
        },
        {
            "type": "git",
            "url": "https://github.com/wernerkrauss/silverstripe-ideannotator.git"
        },
        {
            "type": "git",
            "url": "https://github.com/wernerkrauss/silverstripe-cms-actions.git"
        }
    ],
    "require": {
        "php": "^8.2",
        "silverstripe/recipe-core": "^6",
        "silverstripe/admin": "^3.0",
        "silverstripe/asset-admin": "^3.0",
        "silverstripe/siteconfig": "^6.0",
        "ext-intl": "*",
        "ext-json": "*",
        "atwx/silverstripe-vitehelper": "^1.0"
    },
    "require-dev": {
        "silverleague/ideannotator": "dev-silverstripe6 as 4.0",
        "wernerkrauss/silverstripe-rector": "^1",
        "cambis/silverstan": "^2",
        "squizlabs/php_codesniffer": "^3",
        "phpstan/extension-installer": "^1.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "lint": "vendor/bin/phpcs",
        "fix": "vendor/bin/phpcbf",
        "rector": "vendor/bin/rector -v",
        "rector-dry": "vendor/bin/rector -v --dry-run",
        "phpstan": "vendor/bin/phpstan"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "silverstripe/recipe-plugin": true,
            "silverstripe/vendor-plugin": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "expose": [
            "app/client/dist"
        ],
        "project-files-installed": [
            ".htaccess",
            "app/.htaccess",
            "app/_config.php",
            "app/_config/mimevalidator.yml",
            "app/_config/mysite.yml"
        ],
        "public-files-installed": [
            ".htaccess",
            "index.php",
            "web.config"
        ]
    }
}

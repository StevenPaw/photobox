{
    "name": "atwx/nopages-silverstripe-template",
    "type": "project",
    "authors": [
        {
            "name": "Steffen Kahl",
            "email": "sk@adiwidjaja.com"
        }
    ],
    "repositories": [
        {
            "type": "git",
            "url": "https://github.com/StevenPaw/silverstripe-cms-theme.git"
        }
    ],
    "require": {
        "php": "^8.3",
        "silverstripe/recipe-core": "^6.1",
        "silverstripe/admin": "^3.1",
        "silverstripe/asset-admin": "^3.1",
        "ext-json": "*",
        "atwx/silverstripe-vitehelper": "^1.0",
        "silverstripe/login-forms": "^6.2"
    },
    "require-dev": {
        "silverleague/ideannotator": "4.0",
        "wernerkrauss/silverstripe-rector": "^1",
        "cambis/silverstan": "^2",
        "squizlabs/php_codesniffer": "^3",
        "phpstan/extension-installer": "^1.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "lint": "vendor/bin/phpcs",
        "fix": "vendor/bin/phpcbf",
        "rector": "vendor/bin/rector -v",
        "rector-dry": "vendor/bin/rector -v --dry-run",
        "phpstan": "vendor/bin/phpstan"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "silverstripe/recipe-plugin": true,
            "silverstripe/vendor-plugin": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "expose": [
            "app/client/dist"
        ],
        "project-files-installed": [
            ".htaccess",
            "app/.htaccess",
            "app/_config.php",
            "app/_config/mimevalidator.yml",
            "app/_config/mysite.yml"
        ],
        "public-files-installed": [
            ".htaccess",
            "index.php",
            "web.config"
        ]
    }
}
